# EditorConfig is awesome: https://EditorConfig.org
# Top-most EditorConfig file
root = true

# ================================================
# Default settings for all files
# ================================================
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# ================================================
# Shell Scripts (Bash)
# ================================================
[*.sh]
indent_style = space
indent_size = 2
max_line_length = 100

# ================================================
# PowerShell Scripts
# ================================================
[*.{ps1,psm1,psd1}]
indent_style = space
indent_size = 4
max_line_length = 120

# ================================================
# Markdown Files
# ================================================
[*.{md,mdx}]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false
max_line_length = 80

# ================================================
# YAML Files
# ================================================
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# ================================================
# JSON Files
# ================================================
[*.{json,jsonc}]
indent_style = space
indent_size = 2

# ================================================
# Configuration Files
# ================================================
[.*rc]
indent_style = space
indent_size = 2

[.git*]
indent_style = tab

# ================================================
# Windows Batch Files
# ================================================
[*.{bat,cmd}]
indent_style = space
indent_size = 4
end_of_line = crlf

# ================================================
# Documentation and Text
# ================================================
[*.txt]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

# ================================================
# License and Version files
# ================================================
[LICENSE]
indent_style = space
indent_size = 2

[VERSION]
insert_final_newline = false
